<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dices LLC | Professional Exterior Cleaning OKC</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --dices-blue: #00a8ff;
            --dices-yellow: #fbc531;
            --dices-black: #1e272e;
            --white: #ffffff;
        }

        body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; color: var(--dices-black); line-height: 1.6; }
        
        header { 
            background: var(--dices-black); 
            padding: 10px 5%; 
            display: flex; justify-content: space-between; align-items: center; 
            border-bottom: 4px solid var(--dices-yellow);
            position: sticky; top: 0; z-index: 1000;
        }
        .header-logo { display: flex; align-items: center; gap: 15px; }
        .header-logo img { height: 70px; }
        .header-text { color: white; }
        .header-text h1 { margin: 0; font-size: 1.5rem; letter-spacing: 1px; }
        .header-text span { color: var(--dices-blue); }

        /* Welcoming Hero Section */
        .hero { 
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('van.jpg'); 
            background-size: cover; background-position: center;
            height: 80vh; display: flex; flex-direction: column; justify-content: center; 
            align-items: center; text-align: center; color: white; padding: 0 20px;
        }
        .hero h2 { font-size: 3rem; text-transform: uppercase; margin-bottom: 10px; }
        .hero p { font-size: 1.4rem; color: var(--dices-yellow); font-weight: bold; margin-bottom: 30px; }
        .btn-main { 
            background: var(--dices-blue); color: white; padding: 15px 35px; 
            text-decoration: none; border-radius: 50px; font-weight: 900; font-size: 1.2rem;
            border: 2px solid var(--dices-blue); transition: 0.3s;
        }
        .btn-main:hover { background: var(--dices-yellow); color: var(--dices-black); border-color: var(--dices-yellow); }

        /* Trust & Financing Bar */
        .highlight-bar { background: var(--dices-yellow); padding: 15px; text-align: center; font-weight: bold; font-size: 1.2rem; }

        /* Equipment & On-Time Section */
        .features { padding: 60px 10%; display: flex; flex-wrap: wrap; gap: 40px; align-items: center; background: #f9f9f9; }
        .feature-img { flex: 1; min-width: 300px; }
        .feature-img img { width: 100%; border-radius: 15px; box-shadow: 10px 10px 0 var(--dices-blue); }
        .feature-text { flex: 1; min-width: 300px; }
        .feature-text h3 { font-size: 2rem; color: var(--dices-black); }
        .feature-text ul { list-style: none; padding: 0; }
        .feature-text li { margin-bottom: 15px; font-size: 1.1rem; }
        .feature-text i { color: var(--dices-blue); margin-right: 10px; }

        /* Services Gallery */
        .gallery { padding: 60px 5%; text-align: center; }
        .gallery h2 { font-size: 2.5rem; margin-bottom: 40px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .grid-item { position: relative; border-radius: 10px; overflow: hidden; height: 300px; border-bottom: 5px solid var(--dices-blue); }
        .grid-item img { width: 100%; height: 100%; object-fit: cover; }
        .grid-label { position: absolute; bottom: 0; width: 100%; background: rgba(0,0,0,0.7); color: white; padding: 10px 0; font-weight: bold; }

        /* Reviews */
        .reviews { padding: 60px 5%; background: var(--dices-black); color: white; text-align: center; }
        .review-flex { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin-top: 30px; }
        .card { background: #2c3e50; padding: 25px; border-radius: 10px; width: 300px; text-align: left; }
        .stars { color: var(--dices-yellow); margin-bottom: 10px; }

        footer { background: #111; color: white; padding: 40px 5%; text-align: center; }
        .social { font-size: 2rem; color: var(--dices-yellow); margin-bottom: 15px; display: block; }
    </style>
</head>
<body>

