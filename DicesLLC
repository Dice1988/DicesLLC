<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dices LLC | Professional Pressure Washing OKC</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --dices-blue: #00a8ff;
            --dices-yellow: #fbc531;
            --dices-black: #1e272e;
            --white: #ffffff;
        }

        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; margin: 0; color: var(--dices-black); line-height: 1.6; background-color: #f4f4f4; }
        
        /* Welcoming Header */
        header { 
            background: var(--dices-black); 
            color: var(--white); 
            padding: 15px 5%; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            border-bottom: 5px solid var(--dices-yellow);
            position: sticky; top: 0; z-index: 1000;
        }
        .logo-container { display: flex; align-items: center; gap: 15px; }
        .logo-container img { height: 60px; border-radius: 5px; }
        .contact-top { text-align: right; font-weight: bold; }
        .contact-top span { color: var(--dices-yellow); }

        /* Hero Section */
        .hero { 
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=1200');
            background-size: cover; background-position: center;
            height: 70vh; display: flex; flex-direction: column; justify-content: center; 
            align-items: center; text-align: center; color: var(--white); padding: 0 20px;
        }
        .hero h1 { font-size: 3.5rem; margin: 0; text-transform: uppercase; border-bottom: 4px solid var(--dices-blue); }
        .hero p { font-size: 1.5rem; margin: 20px 0; color: var(--dices-yellow); font-weight: bold; }
        .cta-btn { 
            background: var(--dices-blue); color: white; padding: 15px 40px; 
            text-decoration: none; border-radius: 50px; font-weight: 900; 
            font-size: 1.2rem; transition: 0.3s; border: 2px solid var(--dices-blue);
        }
        .cta-btn:hover { background: var(--dices-yellow); color: var(--dices-black); border-color: var(--dices-yellow); }

        /* Trust Bar */
        .trust-bar { background: var(--dices-yellow); color: var(--dices-black); padding: 15px; text-align: center; font-weight: bold; font-size: 1.1rem; }

        /* Services Grid */
        .services { padding: 60px 5%; text-align: center; }
        .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 40px; }
        .service-card { 
            background: var(--white); padding: 30px; border-radius: 10px; 
            box-shadow: 0 5px 15px rgba(0,0,0,0.1); border-top: 5px solid var(--dices-blue);
            transition: 0.3s;
        }
        .service-card:hover { transform: translateY(-10px); }
        .service-card i { color: var(--dices-blue); margin-bottom: 15px; }

        /* Financing & Info Section */
        .info-split { display: flex; flex-wrap: wrap; background: var(--dices-black); color: white; padding: 60px 5%; gap: 40px; }
        .info-box { flex: 1; min-width: 300px; }
        .info-box h2 { color: var(--dices-yellow); font-size: 2rem; }
        .highlight { color: var(--dices-blue); font-weight: bold; }

        /* 5-Star Reviews */
        .reviews { padding: 60px 5%; background: #eee; text-align: center; }
        .review-container { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; margin-top: 30px; }
        .review-card { background: white; padding: 20px; border-radius: 10px; width: 300px; text-align: left; position: relative; }
        .stars { color: #f1c40f; margin-bottom: 10px; }
        
        /* Footer */
        footer { background: var(--dices-black); color: white; padding: 40px 5%; text-align: center; }
        .social-links a { color: var(--dices-yellow); font-size: 2rem; margin: 0 10px; }
    </style>
</head>
